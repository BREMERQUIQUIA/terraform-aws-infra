# environments/dev/terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to Git (already in .gitignore)

# ── General ───────────────────────────────────────────────────────
project     = "myapp"
environment = "dev"
region      = "us-east-1"

# ── Network ───────────────────────────────────────────────────────
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# ── EC2 ───────────────────────────────────────────────────────────
# Amazon Linux 2 AMI (us-east-1) — update if using different region
ami_id            = "ami-0c02fb55956c7d316"
instance_type     = "t3.micro"
key_name          = "your-key-pair-name"
ssh_allowed_cidrs = ["YOUR_IP/32"]  # Replace with your IP

# ── RDS ───────────────────────────────────────────────────────────
db_name           = "appdb"
db_username       = "admin"
db_password       = "CHANGE_ME_use_secrets_manager_in_prod"
db_instance_class = "db.t3.micro"
